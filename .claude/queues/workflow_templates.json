{
  "templates": {
    "new_feature_development": {
      "name": "New Feature Development",
      "description": "Complete workflow for implementing a new kernel feature",
      "steps": [
        {
          "agent": "requirements-analyst",
          "task": "Analyze feature requirements",
          "description": "Break down feature requirements into implementable components",
          "estimated_duration": "1-2 hours",
          "deliverables": ["Feature specification", "Implementation plan", "Technical constraints"]
        },
        {
          "parallel": true,
          "steps": [
            {
              "agent": "cpp-developer",
              "task": "Implement C++ components",
              "description": "Build development tools and testing infrastructure",
              "estimated_duration": "3-5 hours",
              "deliverables": ["C++ code", "Unit tests", "Build integration"]
            },
            {
              "agent": "assembly-developer",
              "task": "Implement assembly components",
              "description": "Build 6502 kernel code and monitor features",
              "estimated_duration": "4-6 hours",
              "deliverables": ["Assembly code", "Memory map updates", "Hardware integration"]
            }
          ]
        },
        {
          "agent": "testing-agent",
          "task": "Comprehensive testing",
          "description": "Test all components and integration points",
          "estimated_duration": "2-3 hours",
          "deliverables": ["Test results", "Performance validation", "Hardware compatibility"]
        }
      ]
    },
    "bugfix_workflow": {
      "name": "Bug Fix Workflow",
      "description": "Workflow for fixing identified bugs",
      "steps": [
        {
          "agent": "requirements-analyst",
          "task": "Analyze bug report",
          "description": "Understand bug scope and impact",
          "estimated_duration": "30 minutes",
          "deliverables": ["Root cause analysis", "Fix strategy"]
        },
        {
          "condition": "if_cpp_bug",
          "agent": "cpp-developer",
          "task": "Fix C++ bug",
          "description": "Implement fix for C++ components"
        },
        {
          "condition": "if_assembly_bug",
          "agent": "assembly-developer",
          "task": "Fix assembly bug",
          "description": "Implement fix for assembly components"
        },
        {
          "agent": "testing-agent",
          "task": "Validate fix",
          "description": "Ensure bug is fixed and no regressions introduced",
          "estimated_duration": "1 hour",
          "deliverables": ["Test validation", "Regression test results"]
        }
      ]
    },
    "hotfix_workflow": {
      "name": "Critical Hotfix",
      "description": "Fast-track workflow for critical issues",
      "steps": [
        {
          "agent": "assembly-developer",
          "task": "Implement hotfix",
          "description": "Quick fix for critical kernel issues",
          "estimated_duration": "1-2 hours",
          "priority": "critical"
        },
        {
          "agent": "testing-agent",
          "task": "Emergency validation",
          "description": "Critical path testing only",
          "estimated_duration": "30 minutes",
          "priority": "critical"
        }
      ]
    },
    "performance_optimization": {
      "name": "Performance Optimization",
      "description": "Workflow for optimizing system performance",
      "steps": [
        {
          "agent": "testing-agent",
          "task": "Profile current performance",
          "description": "Establish baseline performance metrics",
          "estimated_duration": "1 hour"
        },
        {
          "parallel": true,
          "steps": [
            {
              "agent": "cpp-developer",
              "task": "Optimize C++ code",
              "description": "Improve development tool performance"
            },
            {
              "agent": "assembly-developer",
              "task": "Optimize assembly code",
              "description": "Improve kernel performance and memory usage"
            }
          ]
        },
        {
          "agent": "testing-agent",
          "task": "Validate improvements",
          "description": "Measure performance gains and ensure stability",
          "estimated_duration": "1-2 hours"
        }
      ]
    },
    "documentation_update": {
      "name": "Documentation Update",
      "description": "Workflow for updating project documentation",
      "steps": [
        {
          "agent": "requirements-analyst",
          "task": "Audit documentation needs",
          "description": "Identify gaps and outdated information",
          "estimated_duration": "1 hour"
        },
        {
          "parallel": true,
          "steps": [
            {
              "agent": "cpp-developer",
              "task": "Update C++ documentation",
              "description": "Update API docs and usage examples"
            },
            {
              "agent": "assembly-developer",
              "task": "Update assembly documentation",
              "description": "Update kernel docs and monitor command references"
            }
          ]
        },
        {
          "agent": "testing-agent",
          "task": "Validate documentation accuracy",
          "description": "Test examples and verify technical accuracy"
        }
      ]
    }
  }
}