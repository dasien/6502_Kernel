# Context Forge API keys
.context-forge-api

# CMake build directories
cmake-build-*/
build/
out/

# Compiled executable output (root-level build artifact)
/bin/

# CMake cache and files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Build system files
build.ninja
.ninja_deps
.ninja_log
compile_commands.json

# IDE files
.vscode/
.idea/
*.user
*.pro.user*

# OS specific files
.DS_Store
Thumbs.db

# Backup files
*.bak
*.tmp

# Kernel build artifacts (should be in cmake-build-*/ instead)
/kernel/
kernel.map
kernel.rom
kernel.o

# Qt auto-generated files and directories
*_autogen/
**/moc_*.cpp
**/moc_*.h
moc_*.cpp
moc_*.h
.qt/
**/.qt/

# Test executables are built inside the already-ignored build dirs
# (build/, cmake-build-*/), so they need no separate rule here.
# Do NOT add unanchored patterns like "*tests" or "*_test": they also match
# the tests/ source directory and silently ignore new test source files.
*_test.exe
test_*.exe

# Google Test build artifacts (already covered by cmake-build-*/ but being explicit)
**/googletest-*/
**/googlemock-*/

# Test output files
test_results.xml
*.gcov
*.gcda
*.gcno

# Agent logs
.claude/logs/*.log
enhancements/*/logs/
