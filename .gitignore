# Context Forge API keys
.context-forge-api

# CMake build directories
cmake-build-*/
build/
out/

# CMake cache and files
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
Makefile

# Build system files
build.ninja
.ninja_deps
.ninja_log
compile_commands.json

# IDE files
.vscode/
.idea/
*.user
*.pro.user*

# OS specific files
.DS_Store
Thumbs.db

# Backup files
*.bak
*.tmp

# Kernel build artifacts (should be in cmake-build-*/ instead)
/kernel/
kernel.map
kernel.rom
kernel.o

# Qt auto-generated files and directories
*_autogen/
**/moc_*.cpp
**/moc_*.h
moc_*.cpp
moc_*.h
.qt/
**/.qt/

# Test artifacts (executables built in cmake-build-*/tests/)
*test
*tests
*_test
*_tests
test_*.exe
*_test.exe

# Google Test build artifacts (already covered by cmake-build-*/ but being explicit)
**/googletest-*/
**/googlemock-*/

# Test output files
test_results.xml
*.gcov
*.gcda
*.gcno

# Agent logs
.claude/logs/*.log
enhancements/*/logs/
